APP_NAME="Enterprise Ticketing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=elts_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@elts.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

SCRIBE_AUTH_KEY=

# Ticket defaults
TICKET_DEFAULT_PRIORITY=medium
TICKET_NUMBER_PREFIX=TKT
TICKET_NUMBER_PADDING=5
TICKET_AUTO_CLOSE_DAYS=7
TICKET_MAX_ATTACHMENT_MB=10
TICKET_PER_PAGE=25

# SLA defaults (hours)
SLA_RESPONSE_CRITICAL=1
SLA_RESPONSE_HIGH=4
SLA_RESPONSE_MEDIUM=8
SLA_RESPONSE_LOW=24
SLA_RESOLUTION_CRITICAL=4
SLA_RESOLUTION_HIGH=24
SLA_RESOLUTION_MEDIUM=72
SLA_RESOLUTION_LOW=168
SLA_WARNING_THRESHOLD=75

# CSAT / NPS
CSAT_DELAY_HOURS=1
NPS_FREQUENCY_DAYS=90
SURVEY_TOKEN_EXPIRY_DAYS=7

# Security
REQUIRE_2FA_ROLES=super_admin
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Portal
PORTAL_REGISTRATION_ENABLED=true
PORTAL_EMAIL_VERIFICATION=true

OTP_ENABLED=true
OTP_LIFETIME=0
OTP_KEEP_ALIVE=true
OTP_THROW_EXCEPTION=true

IMAP_DEFAULT_ACCOUNT=default
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_PROTOCOL=imap
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=support@example.com
IMAP_PASSWORD=

ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_RETENTION_DAYS=365
